# =============================================================================
# SONOM - Medusa Backend Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Database (Supabase PostgreSQL) ---
# Format: postgres://[user]:[password]@[host]:[port]/[database]
# Get these from your Supabase project dashboard > Project Settings > Database
DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# --- CORS ---
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000

# --- Redis (optional for production) ---
# Leave empty to use local event bus (memory)
REDIS_URL=

# --- JWT & Session Secrets ---
JWT_SECRET=change-this-to-a-random-secret-string
COOKIE_SECRET=change-this-to-another-random-secret-string

# --- Medusa Admin ---
DISABLE_MEDUSA_ADMIN=false
ADMIN_BACKEND_URL=http://localhost:9000

# --- Mercado Pago (Payment Gateway) ---
# Register at https://www.mercadopago.com/developers
MERCADO_PAGO_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MERCADO_PAGO_ACCESS_TOKEN=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- n8n Webhook for SII Chile Automation ---
# URL where your n8n workflow listens for new orders
# n8n will receive order data and generate electronic invoices (boletas) via SII
N8N_ORDER_WEBHOOK_URL=https://your-n8n-instance.com/webhook/medusa-order-placed

# --- File Storage (local for dev, S3 for production) ---
# For production, consider @medusajs/file-s3
UPLOAD_DIR=uploads
