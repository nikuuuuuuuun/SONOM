# =============================================================================
# SONOM - Next.js Storefront Configuration
# Copy this file to .env.local and fill in your values
# =============================================================================

# Publishable API key from Medusa backend
# Create one at: Settings > Publishable API Keys in Medusa Admin
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL of the Medusa backend API server
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Default region (country code)
NEXT_PUBLIC_DEFAULT_REGION=mx

# Base URL of the storefront (used for OG images, canonical URLs)
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# Mercado Pago public key (for frontend payment integration)
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Node environment
NODE_ENV=development
