{
  "name": "sonom-monorepo",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "backend:dev": "turbo dev --filter=@sonom/backend",
    "backend:seed": "turbo seed --filter=@sonom/backend",
    "storefront:dev": "turbo dev --filter=@sonom/storefront",
    "lint": "turbo lint",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "turbo": "^2.0.14",
    "prettier": "^3.2.5"
  }
}
